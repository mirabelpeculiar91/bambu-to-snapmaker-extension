{
  "manifest_version": 3,
  "name": "Bambu to Snapmaker U1",
  "version": "1.0.0",
  "version_name": "1.0 Beta",
  "description": "Convert MakerWorld print profiles directly to Snapmaker U1 format.",
  "permissions": ["downloads"],
  "host_permissions": ["https://makerworld.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://makerworld.com/*/models/*"],
      "js": ["lib/jszip.min.js", "converter.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "injected.js"],
      "matches": ["https://makerworld.com/*"]
    }
  ]
}
